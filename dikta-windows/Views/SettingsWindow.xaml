<Window x:Class="DiktaWindows.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dikta — Settings"
        Width="400" Height="280"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow">
    <Grid Margin="16,14,16,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Hotkey section header -->
        <TextBlock Grid.Row="0" Text="Dictation Hotkey" FontWeight="SemiBold" FontSize="13"/>

        <!-- Modifiers + Key controls -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Modifiers" FontSize="11" Foreground="Gray" Margin="0,0,0,4"/>
                <ListBox x:Name="ModifiersList"
                         SelectionMode="Multiple"
                         Height="78" Width="160"
                         FontSize="12">
                    <ListBoxItem Content="Ctrl"/>
                    <ListBoxItem Content="Shift"/>
                    <ListBoxItem Content="Alt"/>
                    <ListBoxItem Content="Win"/>
                </ListBox>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Key" FontSize="11" Foreground="Gray" Margin="0,0,0,4"/>
                <ComboBox x:Name="KeyCombo" Width="100" HorizontalAlignment="Left" FontSize="12"/>
            </StackPanel>
        </Grid>

        <!-- Placeholder area for future controls (US-008, US-009) -->
        <Border Grid.Row="4"
                BorderThickness="0"
                Background="Transparent"/>

        <!-- Save / Cancel buttons -->
        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Cancel"
                    Width="80" Height="28" Margin="0,0,8,0"
                    Click="CancelButton_Click"/>
            <Button x:Name="SaveButton" Content="Save"
                    Width="80" Height="28"
                    IsDefault="True"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
